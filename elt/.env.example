CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_SECURE=false
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DATABASE=default

# Optional: path to a local copy of the source PLUTO FlatGeobuf file
# (EPSG:4326). If unset or missing, load_pluto.py downloads PLUTO_FGB_URL
# (defaults to a public copy) into elt/.data/ instead.
# PLUTO_FGB_PATH=/path/to/pluto25_shp_wgs.fgb
# PLUTO_FGB_URL=https://pub-449ea338033e4b9b9c4eb640f6f607f2.r2.dev/pluto25_shp_wgs.fgb
